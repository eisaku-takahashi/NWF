{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "NWF Metadata Schema v2.0.1",
    "description": "Metadata schema for NWF Entities. Defines audit, workflow, and traceability information with JSON DSL support.",
    "type": "object",
    "required": [
        "source_spec_id",
        "actor_id",
        "audit_context"
    ],
    "properties": {
        "source_spec_id": {
            "type": "string",
            "description": "Specification ID that defines the data structure.",
            "pattern": "^SPEC-[A-Z0-9_-]+$"
        },
        "actor_id": {
            "type": "string",
            "description": "Actor who created or modified the entity (User, AI, System).",
            "pattern": "^(USR|AI|SYS)-[A-Z0-9_-]+$"
        },
        "audit_context": {
            "type": "object",
            "description": "Audit and transaction tracking information.",
            "required": [
                "last_transaction_id"
            ],
            "properties": {
                "last_transaction_id": {
                    "type": "string",
                    "description": "Last transaction ID associated with this entity.",
                    "pattern": "^TXN-[0-9a-fA-F-]+$"
                },
                "audit_log_ref": {
                    "type": "string",
                    "description": "Reference to audit log entry."
                },
                "created_at": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Entity creation timestamp (ISO 8601 JST)."
                },
                "updated_at": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Last update timestamp (ISO 8601 JST)."
                }
            },
            "additionalProperties": false
        },
        "workflow_context": {
            "type": "object",
            "description": "Workflow execution context.",
            "properties": {
                "workflow_id": {
                    "type": "string",
                    "pattern": "^WKF-[A-Z0-9_-]+$"
                },
                "task_id": {
                    "type": "string"
                },
                "prompt_id": {
                    "type": "string"
                },
                "execution_id": {
                    "type": "string"
                },
                "validation_thresholds": {
                    "type": "object",
                    "description": "Scope-based error thresholds for EscalationEvaluator.",
                    "additionalProperties": {
                        "type": "integer",
                        "minimum": 0
                    }
                },
                "validation_policies": {
                    "type": "object",
                    "description": "Escalation and validation behavior policies.",
                    "properties": {
                        "thresholds": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "integer",
                                "minimum": 0
                            }
                        },
                        "escalation_mode": {
                            "type": "string",
                            "enum": [
                                "strict",
                                "lenient"
                            ]
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        },
        "traceability": {
            "type": "object",
            "description": "Traceability and derivation information.",
            "properties": {
                "derivation_source_id": {
                    "type": "string"
                },
                "derivation_type": {
                    "type": "string",
                    "enum": [
                        "CLONE",
                        "REWRITE",
                        "BRANCH",
                        "MERGE",
                        "IMPORT",
                        "GENERATE"
                    ]
                },
                "parent_entity_id": {
                    "type": "string"
                },
                "related_entity_ids": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "validation_state": {
                    "type": "object",
                    "description": "Deterministic validation execution state.",
                    "required": [
                        "validation_version",
                        "rule_set_hash",
                        "is_deterministic"
                    ],
                    "properties": {
                        "validation_version": {
                            "type": "string",
                            "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
                        },
                        "last_transaction_id": {
                            "type": "string",
                            "description": "Reference transaction ID for validation context."
                        },
                        "rule_set_hash": {
                            "type": "string",
                            "description": "SHA256 hash of applied World Rules."
                        },
                        "evaluation_engine_version": {
                            "type": "string"
                        },
                        "is_deterministic": {
                            "type": "boolean",
                            "const": true
                        }
                    },
                    "additionalProperties": false
                },
                "dsl_context": {
                    "type": "object",
                    "description": "DSL evaluation snapshot context.",
                    "properties": {
                        "applied_rule_hashes": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "evaluation_engine_version": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        },
        "version_info": {
            "type": "object",
            "description": "Version control information.",
            "properties": {
                "entity_version": {
                    "type": "string"
                },
                "schema_version": {
                    "type": "string"
                },
                "spec_version": {
                    "type": "string"
                }
            },
            "additionalProperties": false
        },
        "custom_attributes": {
            "type": "object",
            "description": "Custom extensible metadata fields.",
            "additionalProperties": true
        }
    },
    "additionalProperties": false
}